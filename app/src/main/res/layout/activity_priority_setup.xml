<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/screen_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="16dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SmartNotify"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/brand_cyan"
            android:gravity="start"
            android:paddingHorizontal="16dp"
            android:paddingBottom="16dp"/>

        <LinearLayout
            android:id="@+id/layoutPriorityRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:weightSum="3"
            android:paddingBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="90dp"
                    android:layout_height="90dp">

                    <ImageView
                        android:id="@+id/imgHighRing"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ring_high"/>

                    <GridLayout
                        android:id="@+id/gridHighPreview"
                        android:layout_width="58dp"
                        android:layout_height="58dp"
                        android:layout_centerInParent="true"
                        android:columnCount="3"
                        android:rowCount="3"
                        android:alignmentMode="alignBounds"/>
                </RelativeLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="High Priority"
                    android:textColor="#F20A0A"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="90dp"
                    android:layout_height="90dp">

                    <ImageView
                        android:id="@+id/imgMediumRing"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ring_medium"/>

                    <GridLayout
                        android:id="@+id/gridMediumPreview"
                        android:layout_width="58dp"
                        android:layout_height="58dp"
                        android:layout_centerInParent="true"
                        android:columnCount="3"
                        android:rowCount="3"
                        android:alignmentMode="alignBounds"/>
                </RelativeLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Medium Priority"
                    android:textColor="#E0C942"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="90dp"
                    android:layout_height="90dp">

                    <ImageView
                        android:id="@+id/imgLowRing"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ring_low"/>

                    <GridLayout
                        android:id="@+id/gridLowPreview"
                        android:layout_width="58dp"
                        android:layout_height="58dp"
                        android:layout_centerInParent="true"
                        android:columnCount="3"
                        android:rowCount="3"
                        android:alignmentMode="alignBounds"/>
                </RelativeLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Low Priority"
                    android:textColor="#13AD0D"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Unassigned Apps"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:paddingStart="16dp"
            android:paddingTop="8dp"/>

        <TextView
            android:id="@+id/tvInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Long press and drag apps into High, Medium, or Low rings."
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:paddingStart="16dp"
            android:paddingBottom="8dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvUnassignedApps"
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:padding="8dp"
            android:orientation="horizontal"
            android:clipToPadding="false"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider_color"
            android:layout_marginTop="8dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Focus Time"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:textSize="16sp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Medium priority notifications will be hidden during this time and delivered right after it ends."
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:paddingTop="4dp"
                android:paddingBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_privacy_card"
                android:backgroundTint="@color/card_background"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/tvFocusTime"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="09:00 AM to 01:00 PM"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"/>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_edit"
                    app:tint="@color/text_secondary" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Low Priority Window"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Low priority apps (promotions, food apps) will ONLY notify you during this specific time."
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:paddingTop="4dp"
                android:paddingBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_privacy_card"
                android:backgroundTint="@color/card_background"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/tvLowPriorityTime"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="08:00 PM to 10:00 PM"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"/>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_edit"
                    app:tint="@color/text_secondary" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>